<Window x:Class="RVMS.Views.LimitMassRangeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RVMS.Views"
        mc:Ignorable="d"
        Title="Limit Mass Range" Height="300" Width="280">

    <StackPanel>
        <TextBlock Text="Trim Mass Range?" FontSize="16" HorizontalAlignment="Center" Margin="5 5 5 0"></TextBlock>
        <!-- <CheckBox Name="LimitEnabled"  Content="Check this box to enable mass range limit" Margin="5" HorizontalAlignment="Center" Click="CheckboxChanged"/> -->

        <TextBlock Margin="10 5 10 10" TextAlignment="Center" TextWrapping="Wrap">
            Trimming the Mass Range will help ensure that the plots are automatically autoscaling toward features of interest.
        </TextBlock>

        <TextBlock Margin="10 5 10 10" TextAlignment="Center" TextWrapping="Wrap">
            This feature goes beyond setting the axis limits, 
            it will also filter out data points that are outside the specified range. 
            Exported data will still reflect the full set from the original file.
        </TextBlock>

        <Grid HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Min:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5 5 5 10"/>
            <TextBox Name="MassMin" Grid.Row="3" Grid.Column="1" Width="60" Margin="5 5 5 10" KeyDown="EntryBox_KeyDown" LostFocus="EntryBox_LostFocus"/>
            <TextBlock Text="Max:" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="5 5 5 10"/>
            <TextBox Name="MassMax" Grid.Row="3" Grid.Column="3" Width="60" Margin="5 5 5 10" KeyDown="EntryBox_KeyDown" LostFocus="EntryBox_LostFocus"/>
        </Grid>

        <Button Content="Apply and Close Window" Click="OnClick_CloseAndApplyRange" Width="222"  Margin="0 10 0 5"/>

        <Button Content="Reset and Close Window" Click="OnClick_CloseAndAutoscale" Width="222" Margin="0 0 0 0"/>

    </StackPanel>
</Window>
