<Window x:Class="RVPDA.Views.ResolutionDialogue"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Mass Resolution" Height="225" Width="375" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <StackPanel HorizontalAlignment="Center">
        <Grid Margin="0,10,0,0" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="B0" Content="0" Command="{Binding SelectNumberCommand}" CommandParameter="0" Grid.Column="0" Width="40" Height="40" Margin="5 0 5 0" FontSize="16"/>
            <Button x:Name="B1" Content="1" Command="{Binding SelectNumberCommand}" CommandParameter="1" Grid.Column="1" Width="40" Height="40" Margin="5 0 5 0" FontSize="16"/>
            <Button x:Name="B2" Content="2" Command="{Binding SelectNumberCommand}" CommandParameter="2" Grid.Column="2" Width="40" Height="40" Margin="5 0 5 0" FontSize="16"/>
            <Button x:Name="B3" Content="3" Command="{Binding SelectNumberCommand}" CommandParameter="3" Grid.Column="3" Width="40" Height="40" Margin="5 0 5 0" FontSize="16"/>
            <Button x:Name="B4" Content="4" Command="{Binding SelectNumberCommand}" CommandParameter="4" Grid.Column="4" Width="40" Height="40" Margin="5 0 5 0" FontSize="16"/>
            <Button x:Name="B5" Content="5" Command="{Binding SelectNumberCommand}" CommandParameter="5" Grid.Column="5" Width="40" Height="40" Margin="5 0 5 0" FontSize="16"/>
        </Grid>

        <TextBlock TextWrapping="Wrap" Width="355" TextAlignment="Center" Margin="0,10,0,10">
    Changing the mass resolution will impact the binning procedure used to make the 2D ion map. The setting is based off of number of decimal points.
    The default setting is 0. <LineBreak/> <LineBreak/> For each decimal place included, data size increases by ~10x and calculation times increase by ~100x.
    Should you choose to increase this number, it is recommended that it be done gradually.
        </TextBlock>
        
    </StackPanel>
</Window>