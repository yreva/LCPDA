<Window x:Class="RVPDA.Views.LimitWavelengthRangeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RVPDA.Views"
        mc:Ignorable="d"
        Title="Limit Mass Range" Height="300" Width="310">

    <StackPanel>
        <TextBlock Text="Limit Wavelength Range?" FontSize="16" HorizontalAlignment="Center" Margin="5 5 5 0"></TextBlock>
        <!-- <CheckBox Name="LimitEnabled"  Content="Check this box to enable mass range limit" Margin="5" HorizontalAlignment="Center" Click="CheckboxChanged"/> -->

        <TextBlock Margin="10 5 10 10" TextAlignment="Center" TextWrapping="Wrap">
    Modifying the Wavelength Range will only affect the way data is displayed in the figures. No changes will be made to 
    the underlying data, and data export will reflect the full range of measured data.
        </TextBlock>

        <TextBlock Margin="10 5 10 10" TextAlignment="Center" TextWrapping="Wrap">
Any existing color limit settings will be autoscaled to fit the sliced data.
        </TextBlock>

        <Grid HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Min:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5 5 5 10"/>
            <TextBox Name="MassMin" Grid.Row="3" Grid.Column="1" Width="60" Margin="5 5 5 10" KeyDown="EntryBox_KeyDown" LostFocus="EntryBox_LostFocus"/>
            <TextBlock Text="Max:" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="5 5 5 10"/>
            <TextBox Name="MassMax" Grid.Row="3" Grid.Column="3" Width="60" Margin="5 5 5 10" KeyDown="EntryBox_KeyDown" LostFocus="EntryBox_LostFocus"/>
        </Grid>

        <Button Content="Close Window and Apply Changes" Click="OnClick_CloseAndApplyRange" Width="222"  Margin="0 0 0 3"/>

        <Button Content="Close Window and Show Full Range" Click="OnClick_CloseAndAutoscale" Width="222" Margin="0 0 0 0"/>

    </StackPanel>
</Window>
