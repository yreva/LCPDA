<Window x:Class="RVPDA.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RVPDA"
        mc:Ignorable="d"
        Title="Load Progress" Height="200" Width="500">
    <StackPanel>
        <TextBlock Text="Processing..." HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"/>
        <ProgressBar Name="progressBar" IsIndeterminate="True" Height="20" Width="250" 
                     HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
    </StackPanel>
</Window>
