<Window x:Class="RawVision.Views.ChromatogramPlotOptionsDialogue"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RawVision.Views"
        mc:Ignorable="d"
        Title="Chromatogram Options" Height="300" Width="250">

    <ScrollViewer>
        <StackPanel>

            <Rectangle Margin="5 5" Fill="DarkSlateBlue" Height="3"></Rectangle>

            <Grid Margin="5 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- X Axis Limits -->
                <TextBlock Text="X Axis Limits:" Grid.Row="0" Grid.Column="0" Margin="5" Grid.ColumnSpan="2"/>

                <TextBlock Text="Min:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Width="60" Margin="5" />
                <TextBlock Text="Max:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="5" HorizontalAlignment="Left"/>
                <TextBox Grid.Row="1" Grid.Column="3" Width="60" Margin="5" />

                <!-- Y Axis Limits -->
                <TextBlock Text="Y Axis Limits:" Grid.Row="2" Grid.Column="0" Margin="5" Grid.ColumnSpan="2"/>
                <TextBlock Text="Min:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="3" Grid.Column="1" Width="60" Margin="5"/>
                <TextBlock Text="Max:" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="3" Grid.Column="3" Width="60" Margin="5 5 5 10"/>
            </Grid>

            <Rectangle Margin="5 5" Fill="DarkSlateBlue" Height="3"></Rectangle>

            <Grid Margin="5 5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="1" Text="Show Vertical Line for Current Scan" Margin="5 0" VerticalAlignment="Center"/>
                <CheckBox Grid.Row="0" Grid.Column="0" Name="VLine" Margin="5 0 0 0"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Window>
