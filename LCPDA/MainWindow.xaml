<Window x:Class="RawVision.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RawVision"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="RawVision - MS Edition" Height="680" Width="950"
        KeyboardNavigation.DirectionalNavigation="None"
        Background="Gainsboro"
        Style="{StaticResource WinAll}">

    <Window.Resources>
        <local:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
    </Window.Resources>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New" Click="New_Click"/>
                <!--<MenuItem Header="Open" Click="Open_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>-->
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Mass Resolution" Click="ChangeMassResolution"/>
                <MenuItem Header="Map Scaling" Click="ChangeMapScaling"/>
                <MenuItem Header="Colormap" Click="ChangeColormap"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Click="About_Click"/>
            </MenuItem>

        </Menu>

        <Grid>
        <!-- Top Frame -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="10" HorizontalAlignment="Center">
            <Button x:Name="SelectFileButton" Content="Select File" Width="100" FontSize="12" Command="{Binding OpenFileCommand}"/>
            <TextBox x:Name="FilePathTextBox" Width="550" FontSize="12" Margin="5 0 5 0" Text="{Binding SelectedFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Button x:Name="ReadFileButton" Content="Load File" Width="100" FontSize="12" Command="{Binding LoadFileCommand}" IsEnabled="False"/>
        </StackPanel>

        <!-- Main Content Area (for Chromatogram and Spectrum Canvas) -->
        <Grid Margin="10,50,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- First Frame (Chromatogram Canvas) -->
            <Border BorderBrush="Black" BorderThickness="1" Grid.Row="0">
                <!-- Placeholder for plot (use image or external control for actual plot) -->
                <Grid x:Name="ChromatogramContainer" Margin="0,0,0,0" Height="222"/>
            </Border>

            <!-- Second Frame (Settings Controls for Min RT, Max RT, etc.) -->
            <Grid Grid.Row="1" Margin="0 5 0 5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border BorderBrush="Black" BorderThickness="1" Grid.Row="0">
                    <!-- Placeholder for plot (use image or external control for actual plot) -->
                    <Grid x:Name="SpectrumContainer" Height="275"/>
                </Border>

                <StackPanel Grid.Column="2" Margin="5 5 5 5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- First row -->
                        <Grid Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton Grid.Column="0" Margin="10 0 10 0" Content="1D" GroupName="ChromSetting" IsChecked="{Binding SelectedOption, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Line}"/>
                            <RadioButton Grid.Column="1" Margin="10 0 10 0" Content="2D" GroupName="ChromSetting" IsChecked="{Binding SelectedOption, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Map}"/>
                        </Grid>

                        <!-- First row -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Text1" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Name="IntEntryBox1" Width="100" Margin="5" IsEnabled="False"/>

                        <!-- Second row -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Text2" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="IntEntryBox2" Width="100" Margin="5" IsEnabled="False"/>

                        <!-- Button that spans both columns -->
                        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="+ 10 Scans" HorizontalAlignment="Stretch" Margin="5" Click="IncrementScanNumber"/>

                        <!-- Button that spans both columns -->
                        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="+ 1 Scan" HorizontalAlignment="Stretch" Margin="5" Click="IncrementScanNumber"/>

                        <!-- Third row -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Scan #" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Name="IntEntryBox3" Width="100" Margin="5" Text="{Binding CurrentScanNumber}" KeyDown="TextBox_KeyDown"/>

                        <!-- Button that spans both columns -->
                            <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Content="- 1 Scan" HorizontalAlignment="Stretch" Margin="5" Click="IncrementScanNumber"/>

                        <!-- Button that spans both columns -->
                            <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Content="- 10 Scans" HorizontalAlignment="Stretch" Margin="5" Click="IncrementScanNumber"/>

                        <!-- Fourth row -->
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Text4" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Name="IntEntryBox4" Width="100" Margin="5" IsEnabled="False"/>

                        <!-- Fifth row -->
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Text5" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="9" Grid.Column="1" Name="IntEntryBox5" Width="100" Margin="5" IsEnabled="False"/>
                    </Grid>
                </StackPanel>

            </Grid>

            <!-- Bottom Frame -->
            <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10">
                <Button x:Name="SaveSpectrumButton" Content="Save Spectrum Figure" Width="150" FontSize="12" IsEnabled="False"/>
                <Button x:Name="SaveChromatogramButton" Content="Save Chromatogram Figure" Width="200" FontSize="12" Margin="5 0 5 0" IsEnabled="False"/>
                    <Button x:Name="SaveDataButton" Content="Save All Data as Text" Width="200" FontSize="12" Command="{Binding SaveDataCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
        
    </DockPanel>
</Window>
